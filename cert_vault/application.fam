App(
    appid="cert_vault",
    name="Cert Vault",
    apptype=FlipperAppType.EXTERNAL,
    targets=["f7"],
    entry_point="cert_vault_app",
    requires=["gui", "storage"],
    stack_size=8 * 1024,
    fap_version="0.1",
    fap_category="Crypto",
    fap_description="Install and inventory Flipper certificate vault bundles generated from PKCS#12 files.",
    fap_author="Javier Morales",
    fap_weburl="https://github.com/javiermorales36",
)